{
  "name": "rune",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "node --watch --env-file-if-exists=.env.local --import ./scripts/register-ts.mjs src/index.ts",
    "start": "NODE_ENV=production node --env-file-if-exists=.env.local --import ./scripts/register-ts.mjs src/index.ts",
    "mcp:start": "NODE_ENV=production node --env-file-if-exists=.env.local --import ./scripts/register-ts.mjs src/mcp/daemon.ts",
    "build": "tsc --noEmit",
    "cli": "node --env-file-if-exists=.env.local --import ./scripts/register-ts.mjs cli/rune.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "evals": "node --env-file-if-exists=.env.local --import ./scripts/register-ts.mjs scripts/run-evals.ts",
    "intent-scan": "node --env-file-if-exists=.env.local --import ./scripts/register-ts.mjs scripts/run-intent-scan.ts",
    "library-backfill": "node --env-file-if-exists=.env.local --import ./scripts/register-ts.mjs scripts/library-backfill.ts",
    "dispatch-review": "node --env-file-if-exists=.env.local --import ./scripts/register-ts.mjs scripts/dispatch-review.ts",
    "acceptance:rebrand": "node --env-file-if-exists=.env.local --import ./scripts/register-ts.mjs scripts/run-rune-rebrand-acceptance.ts",
    "acceptance:orchestrated": "node --env-file-if-exists=.env.local --import ./scripts/register-ts.mjs src/jobs/__acceptance__/orchestrated-live.acceptance.ts",
    "acceptance:cockpit-real": "node --env-file-if-exists=.env.local --import ./scripts/register-ts.mjs src/server/__acceptance__/cockpit-real-product.acceptance.ts"
  },
  "engines": {
    "node": ">=22.15.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "esbuild": "^0.27.7",
    "node-cron": "^4.2.1",
    "node-telegram-bot-api": "^0.67.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/node-telegram-bot-api": "^0.64.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.5",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.3",
    "yaml": "^2.8.3"
  }
}
