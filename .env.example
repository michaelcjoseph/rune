# Telegram Bot (required)
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_USER_ID=your-numeric-user-id

# Vault path — Rune has full read/write access (required)
VAULT_DIR=~/workspace/pkms
# Workspace root — agents receive read-only context (optional)
RUNE_WORKSPACE_DIR=/Users/you/workspace

# Secret for authenticated HTTP endpoints (required)
RUNE_HTTP_SECRET=change-me-random-secret
# Comma-separated allowed Host header values for the HTTP server (optional; defaults to localhost,127.0.0.1)
# RUNE_ALLOWED_HOSTS=localhost,127.0.0.1
# Vault display name injected into the webview for Obsidian wikilinks (optional; defaults to basename of VAULT_DIR)
# OBSIDIAN_VAULT_NAME=pkms
# Runtime logs directory (optional; defaults to ./logs)
# RUNE_LOGS_DIR=/Users/you/workspace/rune/logs
# launchd label used by the cockpit "Restart server" action (optional; defaults to com.jarvis.daemon)
# LAUNCHD_LABEL=com.jarvis.daemon
# Legacy web-process /mcp issuer setting; standalone MCP daemon uses RUNE_MCP_ISSUER_URL.
# MCP_ISSUER_URL=https://your-legacy-web-mcp-host.example

# Standalone MCP daemon (optional unless using the Claude App connector)
# Secret entered on the MCP OAuth consent screen.
RUNE_MCP_SECRET=change-me-random-secret
# Public HTTPS issuer origin for the MCP daemon, typically a Tailscale Funnel/Serve hostname.
RUNE_MCP_ISSUER_URL=https://your-mcp-funnel-host.example
# Defaults shown for clarity; uncomment only when overriding.
# RUNE_MCP_OAUTH_STORE_FILE=logs/rune-mcp-oauth-store.json
# RUNE_MCP_HOST=127.0.0.1
# RUNE_MCP_PORT=3848
# RUNE_MCP_TOOL_TIMEOUT_MS=30000

# Global default for the orchestrated-work dispatch toggle (project 14; optional,
# default off). When 'true', the cockpit Start action dispatches the Rune-owned
# orchestrated product-team loop instead of legacy `/work --auto`. A per-product
# `orchestratedMode` in policies/products.json overrides this default.
# ORCHESTRATED_WORK_ENABLED=false

# Whoop Integration
WHOOP_CLIENT_ID=xx-xx-xx
WHOOP_CLIENT_SECRET=your-whoop-client-secret
