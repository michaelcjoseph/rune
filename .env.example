# Telegram Bot (required)
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_USER_ID=your-numeric-user-id

# Vault path (required)
VAULT_DIR=~/Library/Mobile Documents/iCloud~md~obsidian/Documents/your-vault-name

# Secret for authenticated HTTP endpoints (optional, recommended)
# JARVIS_HTTP_SECRET=some-random-secret

# Whoop Integration
WHOOP_CLIENT_ID=xx-xx-xx
WHOOP_CLIENT_SECRET=your-whoop-client-secret