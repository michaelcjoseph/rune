{
  "aura": {
    "class": "external",
    "repoPath": "~/workspace/aura",
    "baseBranch": "main",
    "credentialsFile": "~/.config/rune/credentials/aura/.env",
    "egressAllowlist": [
      "github.com",
      "api.github.com",
      "codeload.github.com",
      "objects.githubusercontent.com",
      "registry.npmjs.org"
    ]
  },
  "assay": {
    "class": "external",
    "repoPath": "~/workspace/assay",
    "baseBranch": "main",
    "credentialsFile": "~/.config/rune/credentials/assay/.env",
    "egressAllowlist": [
      "github.com",
      "api.github.com",
      "codeload.github.com",
      "objects.githubusercontent.com",
      "registry.npmjs.org"
    ]
  },
  "rune": {
    "class": "internal",
    "repoPath": "~/workspace/rune",
    "baseBranch": "main",
    "orchestratedMode": true,
    "credentialsFile": "~/.config/rune/credentials/rune/.env",
    "egressAllowlist": [
      "github.com",
      "api.github.com",
      "codeload.github.com",
      "objects.githubusercontent.com",
      "registry.npmjs.org"
    ],
    "validationCommands": [
      "npm run build",
      "npm test"
    ]
  },
  "rune-mcp": {
    "class": "internal",
    "repoPath": "~/workspace/rune",
    "baseBranch": "main",
    "orchestratedMode": true,
    "credentialsFile": "~/.config/rune/credentials/rune-mcp/.env",
    "egressAllowlist": [
      "github.com",
      "api.github.com",
      "codeload.github.com",
      "objects.githubusercontent.com",
      "registry.npmjs.org"
    ],
    "validationCommands": [
      "npm run build",
      "npm test"
    ]
  },
  "relay": {
    "class": "external",
    "repoPath": "~/workspace/relay",
    "baseBranch": "main",
    "credentialsFile": "~/.config/rune/credentials/relay/.env",
    "egressAllowlist": [
      "github.com",
      "api.github.com",
      "codeload.github.com",
      "objects.githubusercontent.com",
      "registry.npmjs.org"
    ]
  },
  "writing": {
    "class": "external",
    "scopePath": "docs/rune"
  },
  "brand": {
    "class": "external"
  }
}
