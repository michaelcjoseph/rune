{
  "aura": {
    "repoPath": "~/workspace/aura",
    "baseBranch": "main",
    "credentialsFile": "~/.config/rune/credentials/aura/.env",
    "egressAllowlist": [
      "github.com",
      "api.github.com",
      "codeload.github.com",
      "objects.githubusercontent.com",
      "registry.npmjs.org"
    ]
  },
  "assay": {
    "repoPath": "~/workspace/assay",
    "baseBranch": "main",
    "credentialsFile": "~/.config/rune/credentials/assay/.env",
    "egressAllowlist": [
      "github.com",
      "api.github.com",
      "codeload.github.com",
      "objects.githubusercontent.com",
      "registry.npmjs.org"
    ]
  },
  "rune": {
    "repoPath": "~/workspace/rune",
    "baseBranch": "main",
    "orchestratedMode": true,
    "credentialsFile": "~/.config/rune/credentials/rune/.env",
    "egressAllowlist": [
      "github.com",
      "api.github.com",
      "codeload.github.com",
      "objects.githubusercontent.com",
      "registry.npmjs.org"
    ],
    "validationCommands": [
      "npm run build",
      "npm test"
    ]
  },
  "relay": {
    "repoPath": "~/workspace/relay",
    "baseBranch": "main",
    "credentialsFile": "~/.config/rune/credentials/relay/.env",
    "egressAllowlist": [
      "github.com",
      "api.github.com",
      "codeload.github.com",
      "objects.githubusercontent.com",
      "registry.npmjs.org"
    ]
  }
}
